#!/usr/bin/env bash
#
# agentboard CLI — lightweight wrapper for the Agentboard REST API
#
# Usage:
#   agentboard heartbeat <message>
#   agentboard initiative create <name> [kind]
#   agentboard initiative list
#   agentboard plan create <initiative> <title>
#   agentboard plan list <initiative>
#   agentboard plan start <initiative> <plan-id>
#   agentboard plan done <initiative> <plan-id>
#   agentboard plan block <initiative> <plan-id>
#   agentboard step create <initiative> <plan-id> <title> [order]
#   agentboard step list <initiative> <plan-id>
#   agentboard step start <initiative> <plan-id> <step-id>
#   agentboard step done <initiative> <plan-id> <step-id>
#   agentboard step block <initiative> <plan-id> <step-id>
#   agentboard task create <initiative> <title> [priority]
#   agentboard task start <initiative> <task-id>
#   agentboard task done <initiative> <task-id>
#   agentboard task block <initiative> <task-id>
#   agentboard activity [limit]
#   agentboard register [agent-name] [description]
#   agentboard status
#
# Environment:
#   AGENTBOARD_URL   — Server URL (default: http://localhost:4040)
#   AGENTBOARD_BOARD — Board ID (default: agentboard)
#   AGENTBOARD_AGENT — Agent ID (required for most commands)

set -euo pipefail

# Auto-source config from project root (walk up to find .agentboard)
_dir="$(pwd)"
while [ "$_dir" != "/" ]; do
  if [ -f "$_dir/.agentboard" ]; then
    source "$_dir/.agentboard"
    break
  fi
  _dir="$(dirname "$_dir")"
done

URL="${AGENTBOARD_URL:-http://localhost:4040}"
BOARD="${AGENTBOARD_BOARD:-agentboard}"
AGENT="${AGENTBOARD_AGENT:-}"

api() {
  curl -s -X "$1" "${URL}${2}" \
    -H "Content-Type: application/json" \
    ${3:+-d "$3"}
}

case "${1:-help}" in
  register)
    NAME="${2:-$AGENT}"
    DESC="${3:-AI agent}"
    if [ -z "$NAME" ]; then
      echo "Error: provide agent name or set AGENTBOARD_AGENT" >&2
      exit 1
    fi
    api POST "/api/boards/${BOARD}/agents" \
      "{\"name\":\"${NAME}\",\"description\":\"${DESC}\",\"metadata\":{}}"
    ;;

  heartbeat|hb)
    if [ -z "$AGENT" ]; then echo "Error: set AGENTBOARD_AGENT" >&2; exit 1; fi
    MSG="${2:-alive}"
    api POST "/api/boards/${BOARD}/agents/${AGENT}/heartbeat" \
      "{\"message\":\"${MSG}\"}"
    ;;

  initiative)
    case "${2:-}" in
      create)
        NAME="${3:?initiative name required}"
        KIND="${4:-thread}"
        api POST "/api/boards/${BOARD}/initiatives" \
          "{\"name\":\"${NAME}\",\"kind\":\"${KIND}\"}"
        ;;
      list)
        api GET "/api/boards/${BOARD}/initiatives"
        ;;
      *)
        echo "Usage: agentboard initiative {create|list} [args...]" >&2
        exit 1
        ;;
    esac
    ;;

  plan)
    if [ -z "$AGENT" ]; then echo "Error: set AGENTBOARD_AGENT" >&2; exit 1; fi
    case "${2:-}" in
      create)
        INITIATIVE="${3:?initiative-id required}"
        TITLE="${4:?plan title required}"
        api POST "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans" \
          "{\"title\":\"${TITLE}\",\"ownerAgentId\":\"${AGENT}\"}"
        ;;
      list)
        INITIATIVE="${3:?initiative-id required}"
        api GET "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans"
        ;;
      start)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}" \
          '{"status":"in_progress"}'
        ;;
      done)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}" \
          '{"status":"done"}'
        ;;
      block)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}" \
          '{"status":"blocked"}'
        ;;
      *)
        echo "Usage: agentboard plan {create|list|start|done|block} <initiative> <plan> [args...]" >&2
        exit 1
        ;;
    esac
    ;;

  step)
    if [ -z "$AGENT" ]; then echo "Error: set AGENTBOARD_AGENT" >&2; exit 1; fi
    case "${2:-}" in
      create)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        TITLE="${5:?step title required}"
        ORDER="${6:-}"
        if [ -n "$ORDER" ]; then
          api POST "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps" \
            "{\"title\":\"${TITLE}\",\"assigneeAgentId\":\"${AGENT}\",\"order\":${ORDER}}"
        else
          api POST "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps" \
            "{\"title\":\"${TITLE}\",\"assigneeAgentId\":\"${AGENT}\"}"
        fi
        ;;
      list)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        api GET "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps"
        ;;
      start)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        STEP="${5:?step-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps/${STEP}" \
          '{"status":"in_progress"}'
        ;;
      done)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        STEP="${5:?step-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps/${STEP}" \
          '{"status":"done"}'
        ;;
      block)
        INITIATIVE="${3:?initiative-id required}"
        PLAN="${4:?plan-id required}"
        STEP="${5:?step-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/plans/${PLAN}/steps/${STEP}" \
          '{"status":"blocked"}'
        ;;
      *)
        echo "Usage: agentboard step {create|list|start|done|block} <initiative> <plan> <step> [args...]" >&2
        exit 1
        ;;
    esac
    ;;

  task)
    if [ -z "$AGENT" ]; then echo "Error: set AGENTBOARD_AGENT" >&2; exit 1; fi
    case "${2:-}" in
      create)
        INITIATIVE="${3:?initiative-id required}"
        TITLE="${4:?title required}"
        PRIORITY="${5:-medium}"
        api POST "/api/boards/${BOARD}/initiatives/${INITIATIVE}/tasks" \
          "{\"title\":\"${TITLE}\",\"assigneeAgentId\":\"${AGENT}\",\"actorAgentId\":\"${AGENT}\",\"priority\":\"${PRIORITY}\"}"
        ;;
      start)
        INITIATIVE="${3:?initiative-id required}"
        TASK="${4:?task-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/tasks/${TASK}" \
          "{\"status\":\"in_progress\",\"actorAgentId\":\"${AGENT}\"}"
        ;;
      done)
        INITIATIVE="${3:?initiative-id required}"
        TASK="${4:?task-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/tasks/${TASK}" \
          "{\"status\":\"done\",\"actorAgentId\":\"${AGENT}\"}"
        ;;
      block)
        INITIATIVE="${3:?initiative-id required}"
        TASK="${4:?task-id required}"
        api PATCH "/api/boards/${BOARD}/initiatives/${INITIATIVE}/tasks/${TASK}" \
          "{\"status\":\"blocked\",\"actorAgentId\":\"${AGENT}\"}"
        ;;
      *)
        echo "Usage: agentboard task {create|start|done|block} <initiative> <task> [args...]" >&2
        exit 1
        ;;
    esac
    ;;

  activity)
    LIMIT="${2:-25}"
    api GET "/api/boards/${BOARD}/activity?limit=${LIMIT}"
    ;;

  status)
    echo "=== Board ==="
    api GET "/api/boards/${BOARD}"
    echo ""
    if [ -n "$AGENT" ]; then
      echo "=== Agent ==="
      api GET "/api/boards/${BOARD}/agents/${AGENT}"
      echo ""
    fi
    echo "=== Initiatives ==="
    api GET "/api/boards/${BOARD}/initiatives"
    echo ""
    echo "=== Tasks ==="
    api GET "/api/boards/${BOARD}/tasks"
    echo ""
    echo "=== Activity ==="
    api GET "/api/boards/${BOARD}/activity?limit=10"
    ;;

  help|--help|-h)
    echo "agentboard CLI — report agent status to Agentboard"
    echo ""
    echo "Commands:"
    echo "  register [name] [desc]            Register agent to board"
    echo "  heartbeat <message>               Send heartbeat with status"
    echo "  initiative create <name> [kind]   Create initiative"
    echo "  initiative list                   List initiatives"
    echo "  plan create <init> <title>        Create plan"
    echo "  plan list <init>                  List plans for initiative"
    echo "  plan start <init> <plan-id>       Set plan in_progress"
    echo "  plan done <init> <plan-id>        Set plan done"
    echo "  plan block <init> <plan-id>       Set plan blocked"
    echo "  step create <init> <plan> <title> Create plan step"
    echo "  step list <init> <plan>           List plan steps"
    echo "  step start <init> <plan> <step>   Set step in_progress"
    echo "  step done <init> <plan> <step>    Set step done"
    echo "  step block <init> <plan> <step>   Set step blocked"
    echo "  task create <init> <title> [pri]  Create and assign task"
    echo "  task start <init> <task-id>       Set task in_progress"
    echo "  task done <init> <task-id>        Set task done"
    echo "  task block <init> <task-id>       Set task blocked"
    echo "  activity [limit]                  Show recent activity events"
    echo "  status                            Show board, agent, initiatives, tasks, activity"
    echo ""
    echo "Environment: AGENTBOARD_URL, AGENTBOARD_BOARD, AGENTBOARD_AGENT"
    ;;

  *)
    echo "Unknown command: $1. Run 'agentboard help' for usage." >&2
    exit 1
    ;;
esac
